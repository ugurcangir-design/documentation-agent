# ── Claude / Anthropic ─────────────────────────────────────────────────────
# CLAUDE_BACKEND: 'cli' (Claude Code CLI, varsayılan) veya 'api' (Anthropic SDK)
CLAUDE_BACKEND=cli
# API modunda gerekli; CLI modunda boş bırakılabilir
ANTHROPIC_API_KEY=sk-ant-...

# ── Hedef uygulama (dökümanı yazılacak uygulama) ───────────────────────────
APP_BASE_URL=https://your-app.example.com
APP_USERNAME=your-username
APP_PASSWORD=your-password

# ── Confluence (legacy API token fallback — OAuth tercih edilir) ───────────
CONFLUENCE_BASE_URL=https://your-org.atlassian.net
CONFLUENCE_EMAIL=your@email.com
CONFLUENCE_API_TOKEN=your-confluence-api-token
CONFLUENCE_SPACE_KEY=DOCS
CONFLUENCE_PARENT_PAGE_ID=   # Opsiyonel: üst sayfa ID'si

# ── Agent ayarları ─────────────────────────────────────────────────────────
# 0 → tek-ekran modu (interactive=true, varsayılan ve önerilen).
# >0 → linkleri takip eden çoklu ekran keşfi (deneysel).
MAX_DISCOVERY_DEPTH=0
# Üretilen dokümanın UI öğesi kapsamı bu yüzdenin altındaysa eksik
# öğeler için ek LLM turu (fix-up) tetiklenir. 0-100. Düşürünce hız ↑,
# maliyet ↓, kapsam ↓. 100'e yaklaşınca tersi.
FIX_UP_THRESHOLD=90
# Fix-up kaç tur denesin (0-5). 0 → fix-up tamamen kapalı.
FIX_UP_MAX_PASSES=2
# Coverage LLM-judge: Haiku ile "anlamlı anlatıldı mı?" doğrulaması.
# Substring match'ten daha doğru kapsam metriği (sahte coverage düşer);
# fix-up turu doğru hedeflere yönelir. Maliyet ~$0.005/ekran. Kapatmak
# için 'false' yapın; o zaman saf substring match çalışır.
COVERAGE_LLM_JUDGE=true
# Express server portu. Değiştirirseniz Atlassian developer konsolundaki
# OAuth redirect URI'sini de (http://localhost:<PORT>/api/auth/atlassian/callback)
# yeni portla güncelleyin.
PORT=3000

# ── GitHub Codespaces ──────────────────────────────────────────────────────
# Codespaces'te .env.example → .env olarak kopyalayın:
#   cp .env.example .env
# Ortam değişkenlerini Codespaces secret olarak da tanımlayabilirsiniz:
#   https://github.com/settings/codespaces
