# ── Claude / Anthropic ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Hedef uygulama (dökümanı yazılacak uygulama) ───────────────────────────
APP_BASE_URL=https://your-app.example.com
APP_USERNAME=your-username
APP_PASSWORD=your-password

# ── Confluence ─────────────────────────────────────────────────────────────
CONFLUENCE_BASE_URL=https://your-org.atlassian.net
CONFLUENCE_EMAIL=your@email.com
CONFLUENCE_API_TOKEN=your-confluence-api-token
CONFLUENCE_SPACE_KEY=DOCS
CONFLUENCE_PARENT_PAGE_ID=   # Opsiyonel: üst sayfa ID'si

# ── Agent ayarları ─────────────────────────────────────────────────────────
MAX_DISCOVERY_DEPTH=2          # Kaç seviye derinlikte ekran keşfi yapılsın
PORT=3000                      # Express server portu (default: 3000)

# ── GitHub Codespaces ──────────────────────────────────────────────────────
# Codespaces'te .env.example → .env olarak kopyalayın:
#   cp .env.example .env
# Ortam değişkenlerini Codespaces secret olarak da tanımlayabilirsiniz:
#   https://github.com/settings/codespaces
