# Kullanıcı iş verileri — repoya commit edilmez (gizlilik + her analiste
# yanlış bağlam karışmasını önler). Klasör yapısı .gitkeep ile korunur.
# data/brd/*.md ve data/swagger/*.json contextLoader tarafından DOĞRUDAN
# okunur → commit'lenirse her analize sızar.
data/brd/*
!data/brd/.gitkeep
data/swagger/*
!data/swagger/.gitkeep
data/references/confluence/*
!data/references/confluence/.gitkeep
data/references/documents/*
